# Required for AI summary generation
GEMINI_API_KEY=your-gemini-api-key

# Optional: for audio transcription (Google Speech-to-Text)
# Without these, users must provide transcript manually
GCP_PROJECT_ID=
GCP_CREDENTIALS_PATH=

# JWT secret (min 32 chars) - change in production
JWT_SECRET=change-me-in-production-min-32-characters-long

# Optional: override DB (used by docker-compose; defaults in docker-compose)
# DB_URL=jdbc:postgresql://postgres:5432/meeting_ai
# DB_USER=postgres
# DB_PASSWORD=postgres
